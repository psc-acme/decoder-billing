{
    "name": "psc-acme/decoder-billing",
    "description": "Package decoder-billing for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\DecoderBilling\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "carbon/carbon": "^3.0",
        "psr/cache": "^3.0",
        "symfony/finder": "^7.0",
        "laravel/framework": "^11.0",
        "illuminate/support": "^11.0",
        "psr/container": "^2.0"
    },
    "require-dev": {
        "behat/behat": "^3.14",
        "mockery/mockery": "^1.6",
        "phpstan/phpstan": "^1.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}